{
    "type": "module",
    "main": "lib/index.ts",
    "scripts": {
        "build": "rm -rf dist/ && deno-node-build --root . --out dist/ --entry lib/index.ts && sh tools/packing/build.sh",
        "type-check": "tsc --noEmit",
        "test": "c8 --reporter lcov --reporter html --reporter text --all --src lib/ --exclude lib/snippets/ --exclude test/ mocha test/**/*.ts",
        "lint": "eslint .",
        "update-deps": "npm-check-updates -u"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@k13engineering/eslint-rules": "^0.0.3",
        "@k13engineering/releasetool": "^0.0.5",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.6.0",
        "c8": "^11.0.0",
        "deno-node": "^0.0.12",
        "mocha": "^11.7.5",
        "npm-check-updates": "^20.0.2",
        "syscall-napi": "^0.1.8",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@k13engineering/addon-loader": "^0.0.2"
    }
}
